logs/
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
.venv/
venv/
env/
.env/
*.egg-info/
dist/
build/

# AI artifacts
ai/checkpoints/
ai/__pycache__/
ai/*_pb2.py
ai/*_pb2_grpc.py

